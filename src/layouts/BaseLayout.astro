---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Rafael Lopes | Software Developer",
	description = "Portfolio of Rafael Lopes -- software developer based in Portugal, building modern web applications with React, Node.js, and TypeScript.",
} = Astro.props;

const ogImage = new URL("/portfolio/og-image.png", Astro.site).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="author" content="Rafael Lopes" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={Astro.url.href} />

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded focus:bg-accent-blue focus:px-4 focus:py-2 focus:text-bg-primary focus:font-semibold"
		>
			Skip to content
		</a>
		<slot />
	</body>
</html>
